#!/bin/bash

if [ -z "$1" ]; then
    echo "Usage: nnecs-wallpaper <path_to_image>"
    exit 1
fi

IMG_PATH=$(realpath "$1")

if [ ! -f "$IMG_PATH" ]; then
    echo "Error: Image file not found at $IMG_PATH"
    exit 1
fi

DIR="$HOME/.config/hypr"
cd "$DIR" || exit 1

echo "Generating Matugen colors..."
matugen image "$IMG_PATH"

echo "Applying wallpaper config..."
tmp_hyprpaper=$(mktemp) || { echo "Error: Failed to create temporary file for hyprpaper config" >&2; exit 1; }
if sed "s|@PATH@|$IMG_PATH|g" hyprpaper.template.conf > "$tmp_hyprpaper"; then
    mv "$tmp_hyprpaper" hyprpaper.local.conf
else
    echo "Error: Failed to generate hyprpaper.local.conf" >&2
    rm -f "$tmp_hyprpaper"
    exit 1
fi

echo "Applying hyprlock config..."
tmp_hyprlock=$(mktemp) || { echo "Error: Failed to create temporary file for hyprlock config" >&2; exit 1; }
if sed "s|@PATH@|$IMG_PATH|g" hyprlock.template.conf > "$tmp_hyprlock"; then
    mv "$tmp_hyprlock" hyprlock.local.conf
else
    echo "Error: Failed to generate hyprlock.local.conf" >&2
    rm -f "$tmp_hyprlock"
    exit 1
fi

echo "Applying wallpaper via hyprctl..."
hyprctl hyprpaper wallpaper ",$IMG_PATH" > /dev/null 2>&1

sleep 1

echo "Reloading hyprland..."
hyprctl reload

echo "Done!"

